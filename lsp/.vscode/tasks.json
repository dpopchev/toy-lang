{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile",
      "type": "shell",
      "command": "npm run compile",
      "options": { "cwd": "${workspaceRoot}" },
      "problemMatcher": "$tsc-watch",
      "group": { "kind": "build", "isDefault": true },
      "isBackground": false
    },
    {
      "label": "watch",
      "type": "shell",
      "command": "npm run watch",
      "options": { "cwd": "${workspaceRoot}" },
      "problemMatcher": "$tsc-watch",
      "isBackground": true
    }
  ]
}
